{
  "mcpServers": {
    "next-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "shadcn/ui": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "shadcn@latest",
        "mcp"
      ]
    },
    "magic-ui": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@magicuidesign/mcp@latest"
      ]
    }
  }
}